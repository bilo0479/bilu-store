# Clerk Auth
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Clerk Webhook secret (set in Clerk dashboard → Webhooks → signing secret)
CLERK_WEBHOOK_SECRET=whsec_...

# Convex (P3) — run `npx convex dev` to provision and get this URL
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
# AfricasTalking SMS (P3) — for Clerk custom SMS provider
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Sentry
EXPO_PUBLIC_SENTRY_DSN=

# Algolia
EXPO_PUBLIC_ALGOLIA_APP_ID=
EXPO_PUBLIC_ALGOLIA_SEARCH_KEY=

# Cloudinary
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
