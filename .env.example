# =============================================================================
# Bilu Store — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# ── Clerk (https://dashboard.clerk.com) ──────────────────────────────────────
# Your publishable key from Clerk → API Keys
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Convex (https://dashboard.convex.dev) ────────────────────────────────────
# Printed by `npx convex dev` — looks like https://xxxxx.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

# ── Sentry (https://sentry.io) ───────────────────────────────────────────────
# Project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://XXXXX@oXXXXX.ingest.sentry.io/XXXXXXX

# ── Google AdMob (https://admob.google.com) ──────────────────────────────────
# AdMob → Apps → Ad units. Use test IDs during development (listed below).
# Android test banner:      ca-app-pub-3940256099942544/6300978111
# Android test interstitial: ca-app-pub-3940256099942544/1033173712
# iOS test banner:           ca-app-pub-3940256099942544/2934735716
# iOS test interstitial:     ca-app-pub-3940256099942544/4411468910
EXPO_PUBLIC_ADMOB_BANNER_ANDROID_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_BANNER_IOS_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# =============================================================================
# CONVEX ENVIRONMENT VARIABLES
# Set with: npx convex env set KEY "value"
# These do NOT go in .env — they live in Convex's encrypted env store.
# =============================================================================

# Clerk → API Keys → Secret key
# npx convex env set CLERK_SECRET_KEY "sk_test_xxx"
# CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clerk → Webhooks → Signing secret
# npx convex env set CLERK_WEBHOOK_SECRET "whsec_xxx"
# CLERK_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Turso CLI: turso db show <db-name> --url
# npx convex env set TURSO_URL "libsql://xxx.turso.io"
# TURSO_URL=libsql://YOUR-DB.turso.io

# Turso CLI: turso db tokens create <db-name>
# npx convex env set TURSO_AUTH_TOKEN "eyJ..."
# TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSJ9...

# Chapa → Settings → API Keys
# npx convex env set CHAPA_SECRET_KEY "CHASECK_TEST-xxx"
# CHAPA_SECRET_KEY=CHASECK_TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Chapa → Settings → Webhooks → Secret
# npx convex env set CHAPA_WEBHOOK_SECRET "xxx"
# CHAPA_WEBHOOK_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google reCAPTCHA v3 → Admin Console → site secret
# npx convex env set RECAPTCHA_SECRET_KEY "xxx"
# RECAPTCHA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# AfricasTalking → Settings → API Key
# npx convex env set AFRICAS_TALKING_API_KEY "atsk_xxx"
# AFRICAS_TALKING_API_KEY=atsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# npx convex env set AFRICAS_TALKING_USERNAME "bilustore"
# AFRICAS_TALKING_USERNAME=bilustore

# =============================================================================
# WEB ADMIN DASHBOARD — goes in web/.env.local (never committed)
# =============================================================================

# NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
