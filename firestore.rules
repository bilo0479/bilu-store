rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Migrated collections (P4) — deny all direct client access ──────
    // These are now owned by Turso via Convex Actions.
    match /users/{userId} {
      allow read, write: if false;
    }
    match /ads/{adId} {
      allow read, write: if false;
      match /status_history/{historyId} {
        allow read, write: if false;
      }
    }
    match /reviews/{reviewId} {
      allow read, write: if false;
    }
    match /favorites/{favId} {
      allow read, write: if false;
    }

    // ── Chats — still served from Convex reactive DB (not Firestore) ───
    match /chats/{chatId} {
      allow read, write: if false;
      match /messages/{messageId} {
        allow read, write: if false;
      }
    }

    // ── Reports ─────────────────────────────────────────────────────────
    // Still in Turso (reported via Convex), deny direct client writes.
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // ── Premium ads ─────────────────────────────────────────────────────
    match /premium_ads/{premiumAdId} {
      allow read, write: if false;
    }

    // ── Config — read-only public config still served from Firestore ────
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Payment sessions (legacy, read-only for support) ────────────────
    match /payment_sessions/{sessionId} {
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // ── Escrow — migrated to Turso (P6). Legacy read for support only. ─
    match /escrow_transactions/{txId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.buyerId
                      || request.auth.uid == resource.data.sellerId
                      || isAdmin());
      allow write: if false;
    }
    match /escrow_otps/{txId} {
      allow read, write: if false;
    }

    // ── Helper functions ─────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }
  }
}
