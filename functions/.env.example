# Firebase Cloud Functions — Environment Variables
# Copy this file to .env and fill in your values
# Deploy with: firebase functions:secrets:set or set directly in functions/.env

# Algolia — from Algolia dashboard → API Keys → Admin API Key (write access)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_WRITE_API_KEY=your_algolia_admin_api_key
ALGOLIA_INDEX_NAME=bilu_store_ads
