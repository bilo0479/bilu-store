# Firebase Cloud Functions — Environment Variables
# Copy this file to .env and fill in your values

# Algolia — from Algolia dashboard → API Keys → Admin API Key (write access)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_WRITE_API_KEY=your_algolia_admin_api_key
ALGOLIA_INDEX_NAME=ads

# Chapa — from Chapa dashboard → API Keys
CHAPA_SECRET_KEY=your_chapa_secret_key

# Telebirr OpenAPI — from Ethio Telecom developer portal
# https://developer.ethiotelecom.et/user/dashboard
TELEBIRR_APP_ID=your_appid                        # appid (UUID format)
TELEBIRR_APP_SECRET=your_app_secret               # appSecret
TELEBIRR_MERCHANT_CODE=your_merchant_code         # merch_code (numeric)
TELEBIRR_MERCHANT_ID=your_merchant_id             # merchant appid (numeric)
TELEBIRR_PRIVATE_KEY=your_pkcs8_private_key_base64  # raw base64, no PEM headers
TELEBIRR_GATEWAY_URL=https://196.188.120.3:38443/apiaccess/payment/gateway
